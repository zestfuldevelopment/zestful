#!/bin/bash
# zestful — CLI for interacting with the Zestful agent notification app
# Sends notifications to the Zestful overlay via localhost TCP.

set -e

TOKEN_FILE="$HOME/.config/zestful/local-token"
PORT_FILE="$HOME/.config/zestful/port"
FOCUS_FILE="$HOME/.config/zestful/focus-context"
DEFAULT_PORT=21547
ZESTFULD_PID_FILE="$HOME/.config/zestful/zestfuld.pid"
ZESTFULD_SCRIPT="$HOME/.config/zestful/zestfuld.js"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure zestfuld is running
ensure_zestfuld() {
    if [[ -f "$ZESTFULD_PID_FILE" ]]; then
        local pid
        pid=$(cat "$ZESTFULD_PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    # Install zestfuld.js if not present
    if [[ ! -f "$ZESTFULD_SCRIPT" ]]; then
        local src="$SCRIPT_DIR/zestfuld.js"
        if [[ -f "$src" ]]; then
            mkdir -p "$(dirname "$ZESTFULD_SCRIPT")"
            cp "$src" "$ZESTFULD_SCRIPT"
        fi
    fi
    if [[ -f "$ZESTFULD_SCRIPT" ]]; then
        nohup node "$ZESTFULD_SCRIPT" >/dev/null 2>&1 &
        sleep 0.3
    fi
}

ensure_zestfuld

usage() {
    echo "Usage:"
    echo "  zestful notify --agent <name> --message <msg> [options]"
    echo "  zestful watch <command> [args...]"
    echo "  zestful ssh [user@]host [ssh options...]"
    echo ""
    echo "Commands:"
    echo "  notify    Send a notification to the Zestful overlay"
    echo "  watch     Run a command and notify when it finishes"
    echo "  ssh       SSH with Zestful forwarding (port + token)"
    echo ""
    echo "Notify options:"
    echo "  --agent      Agent name (e.g. claude-code, cursor, aider)"
    echo "  --message    Message to display"
    echo "  --severity   info, warning (default), or urgent"
    echo "  --app        App to focus when alert is clicked (e.g. kitty, Terminal, Cursor)"
    echo "  --window-id  Window ID for focus (app-specific)"
    echo "  --tab-id     Tab ID for focus (app-specific)"
    echo "  --no-push    Suppress push notification for this event"
    echo ""
    echo "Watch options:"
    echo "  --agent      Override agent name (default: watch)"
    echo ""
    echo "Examples:"
    echo "  zestful watch npm run build"
    echo "  zestful watch --agent deploy ./deploy.sh"
    echo "  zestful ssh dev@myserver.com"
    exit 1
}

notify() {
    local agent=""
    local message=""
    local severity="warning"
    local app=""
    local window_id=""
    local tab_id=""
    local push="true"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent="$2"; shift 2 ;;
            --message) message="$2"; shift 2 ;;
            --severity) severity="$2"; shift 2 ;;
            --app) app="$2"; shift 2 ;;
            --window-id) window_id="$2"; shift 2 ;;
            --tab-id) tab_id="$2"; shift 2 ;;
            --no-push) push="false"; shift ;;
            *) shift ;;
        esac
    done

    if [[ -z "$agent" || -z "$message" ]]; then
        echo "Error: --agent and --message are required"
        usage
    fi

    # Read token (try file first, then sandboxed UserDefaults)
    local token
    if [[ -f "$TOKEN_FILE" ]]; then
        token=$(cat "$TOKEN_FILE")
    else
        token=$(defaults read com.caladriuslogic.zestful localServerToken 2>/dev/null || true)
    fi
    if [[ -z "$token" ]]; then
        echo "Error: Zestful app not running or not configured. Token not found."
        exit 2
    fi

    # Read port (try file first, then sandboxed UserDefaults)
    local port=$DEFAULT_PORT
    if [[ -f "$PORT_FILE" ]]; then
        port=$(cat "$PORT_FILE")
    else
        local ud_port
        ud_port=$(defaults read com.caladriuslogic.zestful localServerPort 2>/dev/null || true)
        [[ -n "$ud_port" ]] && port="$ud_port"
    fi

    # Apply saved focus context if --app was not explicitly passed
    if [[ -z "$app" && -f "$FOCUS_FILE" ]]; then
        while IFS='=' read -r key value; do
            case "$key" in
                app) app="$value" ;;
                window_id) [[ -z "$window_id" ]] && window_id="$value" ;;
                tab_id) [[ -z "$tab_id" ]] && tab_id="$value" ;;
            esac
        done < "$FOCUS_FILE"
    fi

    # Escape JSON special characters
    escape_json() {
        printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\n/\\n/g'
    }

    # Build JSON body
    local body="{\"agent\":\"$(escape_json "$agent")\",\"message\":\"$(escape_json "$message")\",\"severity\":\"$(escape_json "$severity")\""
    if [[ -n "$app" ]]; then
        body="$body,\"app\":\"$(escape_json "$app")\""
    fi
    if [[ -n "$window_id" ]]; then
        body="$body,\"window_id\":\"$(escape_json "$window_id")\""
    fi
    if [[ -n "$tab_id" ]]; then
        body="$body,\"tab_id\":\"$(escape_json "$tab_id")\""
    fi
    if [[ "$push" == "false" ]]; then
        body="$body,\"push\":false"
    fi
    body="$body}"

    # Send via curl to localhost
    curl -4 -s -X POST "http://localhost:${port}/notify" \
        -H "X-Zestful-Token: $token" \
        -H "Content-Type: application/json" \
        -d "$body" 2>/dev/null || {
        echo "Error: Could not connect to Zestful. Is the app running?"
        exit 3
    }
}

watch() {
    local agent="watch"

    # Parse optional --agent flag before the command
    if [[ "${1:-}" == "--agent" ]]; then
        agent="$2"
        shift 2
    fi

    if [[ $# -eq 0 ]]; then
        echo "Error: zestful watch requires a command"
        echo "Usage: zestful watch [--agent <name>] <command> [args...]"
        exit 1
    fi

    # Auto-detect terminal for click-to-focus
    local app="${TERM_PROGRAM:-}"

    # Disable set -e so we can capture the exit code
    set +e
    "$@"
    local exit_code=$?
    set -e

    local cmd_name
    cmd_name=$(basename "$1")

    if [[ $exit_code -eq 0 ]]; then
        notify --agent "$agent:$cmd_name" --message "$cmd_name finished" --severity warning ${app:+--app "$app"}
    else
        notify --agent "$agent:$cmd_name" --message "$cmd_name failed (exit $exit_code)" --severity urgent ${app:+--app "$app"}
    fi

    return $exit_code
}

zssh() {
    if [[ $# -eq 0 ]]; then
        echo "Error: zestful ssh requires a host"
        echo "Usage: zestful ssh [user@]host [ssh options...]"
        exit 1
    fi

    # Read local token (try file first, then sandboxed UserDefaults)
    local token
    if [[ -f "$TOKEN_FILE" ]]; then
        token=$(cat "$TOKEN_FILE")
    else
        token=$(defaults read com.caladriuslogic.zestful localServerToken 2>/dev/null || true)
    fi
    if [[ -z "$token" ]]; then
        echo "Error: Zestful app not running. Token not found."
        exit 2
    fi

    # Read local port (try file first, then sandboxed UserDefaults)
    local port=$DEFAULT_PORT
    if [[ -f "$PORT_FILE" ]]; then
        port=$(cat "$PORT_FILE")
    else
        local ud_port
        ud_port=$(defaults read com.caladriuslogic.zestful localServerPort 2>/dev/null || true)
        [[ -n "$ud_port" ]] && port="$ud_port"
    fi

    # Extract the host (first arg that isn't an ssh flag) for scp
    # We parse simply: the first argument is the destination
    local dest="$1"

    # Build focus context from local environment
    local focus_context=""
    if [[ -n "${TERM_PROGRAM:-}" ]]; then
        focus_context="app=${TERM_PROGRAM}"
    fi
    if [[ -n "${KITTY_WINDOW_ID:-}" ]]; then
        focus_context="${focus_context}\nwindow_id=${KITTY_WINDOW_ID}"
    fi

    # Copy token and config to remote in a single SSH session
    echo "Syncing Zestful config to $dest..."
    ssh "$dest" "mkdir -p ~/.config/zestful && chmod 700 ~/.config/zestful"

    # Token
    ssh "$dest" "cat > ~/.config/zestful/local-token && chmod 600 ~/.config/zestful/local-token" < "$TOKEN_FILE"

    # Port
    echo "$port" | ssh "$dest" "cat > ~/.config/zestful/port && chmod 600 ~/.config/zestful/port"

    # Focus context (so remote zestful notify knows which local terminal tab to focus)
    if [[ -n "$focus_context" ]]; then
        echo -e "$focus_context" | ssh "$dest" "cat > ~/.config/zestful/focus-context && chmod 600 ~/.config/zestful/focus-context"
    fi

    echo "Connecting with Zestful forwarding (port $port)..."
    # SSH with reverse port forward — all args passed through
    exec ssh -R "${port}:localhost:${port}" "$@"
}

# Parse command
case "${1:-}" in
    notify) shift; notify "$@" ;;
    watch) shift; watch "$@" ;;
    ssh) shift; zssh "$@" ;;
    --help|-h) usage ;;
    *) usage ;;
esac
