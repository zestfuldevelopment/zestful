{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "notify",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "notify",
        "--agent", "claude-code",
        "--message", "Task complete",
        "--severity", "warning"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "watch",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "watch",
        "echo", "hello"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "daemon",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["daemon"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "ssh",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "ssh",
        "user@hostname"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "focus",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "focus",
        "--app", "Terminal"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "inspect",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "inspect",
        "--pretty"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus"],
      "cwd": "${workspaceFolder}"
    }
  ]
}
