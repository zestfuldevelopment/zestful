{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "notify",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "notify",
        "--agent", "claude-code",
        "--message", "Task complete",
        "--severity", "warning"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "watch",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "watch",
        "echo", "hello"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "daemon",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["daemon"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "ssh",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "ssh",
        "user@hostname"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "focus",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "focus",
        "--app", "Terminal"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "inspect",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": [
        "inspect",
        "--pretty"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (Terminal)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "terminal"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (iTerm2)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "iterm2"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (PowerShell)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "powershell"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (Cmd)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "cmd"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (Windows Terminal)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "windows terminal"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (Chrome)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "chrome"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (VS Code)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "vscode"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "test-focus (Cursor)",
      "preLaunchTask": "kill-zestful",
      "cargo": {
        "args": ["build", "--bin=zestful"]
      },
      "args": ["test-focus", "--app", "cursor"],
      "cwd": "${workspaceFolder}"
    }
  ]
}
